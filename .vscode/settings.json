{
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,

    "**/dist": true,
    "**/coverage": true,
    "**/node_modules": true,
    "**/package-lock.json": true,
    "**/pnpm-*": true,
    "**/.npmignore": true,
