{
  "id": "repository.interface",
  "description": "Create domain repository port.",
  "files": [
    {
      "source": "files/src/Context/Domain/Repository/EntityRepository.ts.tpl",
      "target": "src/{{context}}/Domain/Repository/{{entity}}Repository.ts"
    }
  ],
  "arguments": {
    "context": {
      "required": true,
      "type": "identifier",
      "case": "PascalCase",
      "description": "Bounded context name.",
      "example": "Auth"
    },
    "entity": {
      "required": true,
      "type": "identifier",
      "case": "PascalCase",
      "description": "Domain entity name.",
      "example": "Order"
    }
  },
  "aliases": [],
  "tags": [],
  "requires": [],
  "suggests": [],
  "alternatives": {},
  "preconditions": [],
  "slots": [],
  "example": "ahre code repository.interface --context Auth --entity Order --json",
  "usage": "ahre code repository.interface --context <Context> --entity <Entity> --json"
}
