{
  "name": "ahre-cli",
  "version": "0.9.0",
  "description": "Deterministic capability engine",
  "type": "module",
  "bin": {
    "ahre": "./bin/ahre.mjs"
  },
  "scripts": {
    "start": "node ./bin/ahre.mjs",
    "smoke": "node ./bin/ahre.mjs find \"http service\" --json && node ./bin/ahre.mjs help && node ./bin/ahre.mjs doctor --json",
    "check": "node --check ./src/ahre-cli.mjs && node --check ./bin/ahre.mjs",
    "test": "node ./tests/cli.test.mjs",
    "release:verify": "bash ./scripts/release-verify.sh"
  },
  "keywords": [
    "architecture",
    "recipe-engine",
    "cli",
    "ddd",
    "clean-architecture",
    "agents"
  ],
  "license": "MIT",
  "dependencies": {
    "ts-morph": "^24.0.0"
  }
}
